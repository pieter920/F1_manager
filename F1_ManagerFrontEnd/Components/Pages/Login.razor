@page "/"
@page "/login"
@inject HttpClient Http
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h3>Login</h3>

<div class="mb-3 mt-3">
    <label for="username">Gebruikersnaam:</label>
    <input type="text" class="form-control" id="username" placeholder="gebruikersnaam" @bind="_username" />
</div>

<div class="mb-3">
    <label for="password">Wachtwoord:</label>
    <input type="password" class="form-control" id="password" placeholder="wachtwoord" @bind="_password" />
